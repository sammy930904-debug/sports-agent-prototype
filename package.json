{
    "name": "react-admin",
    "version": "0.1.0",
    "private": true,
    "dependencies": {
        "@ant-design/charts": "v1",
        "@ant-design/icons": "^4.8.0",
        "@ant-design/pro-components": "^1.1.15",
        "@reduxjs/toolkit": "^2.1.0",
        "@tanstack/react-query": "^4.20.9",
        "antd": "4.21.7",
        "axios": "0.21.1",
        "big.js": "^6.2.1",
        "clipboard": "^2.0.11",
        "craco-antd": "^2.0.0",
        "crypto-js": "^4.1.1",
        "html2canvas": "^1.4.1",
        "i18next": "^22.4.6",
        "i18next-browser-languagedetector": "^7.0.1",
        "jspdf": "^2.5.1",
        "lodash": "^4.17.21",
        "moment": "^2.29.4",
        "nanoid": "^4.0.0",
        "nprogress": "^0.2.0",
        "qrcode.react": "^3.1.0",
        "query-string": "^8.1.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-draggable": "^4.4.6",
        "react-error-boundary": "^3.1.4",
        "react-fast-marquee": "^1.6.5",
        "react-i18next": "^12.1.1",
        "react-router": "^6.6.1",
        "react-router-dom": "^6.6.1",
        "react-scripts": "5.0.1",
        "recoil": "^0.7.6",
        "web-vitals": "^2.1.4"
    },
    "scripts": {
        "start": "dotenv -e .env.development craco start",
        "start:test": "dotenv -e .env.test craco start",
        "start:pre-prod": "dotenv -e .env.pre-production craco start",
        "start:prod": "dotenv -e .env.production craco start",
        "build": "dotenv -e .env.production  craco build",
        "build:test": "dotenv -e .env.test craco build",
        "prettier": "prettier --config .prettierrc.cjs --write --list-different \"src/**/*.{js,jsx,ts,tsx,css,scss,less,json,md}\" ",
        "eslint": "eslint --config .eslintrc.cjs --fix --ext .js,.jsx,.ts,.tsx,.json \"src/**/*.{js,ts,tsx,jsx,json}\" ",
        "stylelint": "stylelint --config .stylelintrc.cjs \"src/**/*.{css,less,scss}\" --fix",
        "prepare": "husky install",
        "i18n:pull": "good-i18n-pull --sheet \"https://docs.google.com/spreadsheets/d/1ONWuRkUlpwSCMj044OeADGl8pQadCjIkqD4FmkUOFQM/edit?gid=19683344#gid=19683344\" --sheetName \"体育代理\" --a1 \"A1:Z999\" --out ./src/locales --langMap \"$(cat i18n.langMap.json)\""
    },
    "devDependencies": {
        "@commitlint/cli": "^17.3.0",
        "@commitlint/config-conventional": "^17.3.0",
        "@craco/craco": "^7.0.0",
        "@craco/types": "^7.0.0",
        "@types/big.js": "^6.2.2",
        "@types/crypto-js": "^4.1.1",
        "@types/jest": "^27.5.2",
        "@types/lodash": "^4.14.191",
        "@types/node": "^17.0.45",
        "@types/nprogress": "^0.2.0",
        "@types/react": "^18.0.26",
        "@types/react-dom": "^18.0.10",
        "@typescript-eslint/eslint-plugin": "^5.48.0",
        "@typescript-eslint/parser": "^5.48.0",
        "autoprefixer": "^10.4.13",
        "compression-webpack-plugin": "^10.0.0",
        "craco-plugin-scoped-css": "^1.1.1",
        "craco-sass-loader": "^1.0.2",
        "dotenv-cli": "^6.0.0",
        "eslint": "^8.31.0",
        "eslint-config-prettier": "^8.6.0",
        "eslint-plugin-import": "^2.27.5",
        "eslint-plugin-prettier": "^4.2.1",
        "eslint-plugin-react": "^7.31.11",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-unused-imports": "^2.0.0",
        "husky": "^8.0.0",
        "lint-staged": "^13.1.0",
        "prettier": "^2.8.1",
        "sass": "^1.36.0",
        "sass-resources-loader": "^2.2.5",
        "simplebar-react": "^3.2.4",
        "stylelint": "^13.13.1",
        "stylelint-config-prettier": "^9.0.4",
        "stylelint-config-rational-order": "^0.1.2",
        "stylelint-config-standard": "^22.0.0",
        "stylelint-order": "^5.0.0",
        "typescript": "^4.9.4",
        "webpackbar": "^5.0.2",
        "windicss": "^3.5.6",
        "windicss-webpack-plugin": "^1.7.7"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "lint-staged": {
        "*.{js,json,ts,jsx,tsx}": [
            "pnpm eslint",
            "pnpm prettier"
        ],
        "*.{js,jsx,ts,tsx,css,scss,less,json,md}": [
            "pnpm prettier"
        ],
        "*.{,css,scss,less}": [
            "pnpm stylelint"
        ]
    },
    "engines": {
        "node": ">=16.0.0 <17.0.0",
        "pnpm": ">7.0.0"
    }
}
